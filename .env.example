APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Keep false in production — true leaks stack traces, SQL and env vars on errors.
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3-compatible object storage — MinIO in local dev, Cloudflare R2 in production.
# The `s3` disk reads these AWS_* variables (config/filesystems.php). Set
# FILESYSTEM_DISK=s3 to activate it. For R2 use the values from
# Cloudflare Dashboard → R2 → Manage R2 API tokens.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=nexum-documents
AWS_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

# Initial admin user (AdminUserSeeder) — set real values in production.
ADMIN_EMAIL=admin@nexumcore.app
ADMIN_PASSWORD=
ADMIN_NAME=Administrador

# Singapur relay
SINGAPUR_API_URL=
SINGAPUR_BEARER_TOKEN=
SINGAPUR_WEBHOOK_SECRET=

# MUA bot shared secret (HMAC-SHA256) — must match the bot's config
MUA_BOT_SECRET_KEY=

# Anthropic Claude API key — used for KYC document vision extraction (DocumentAnalysisService)
ANTHROPIC_API_KEY=

# FIEL credentials for local/staging testing only — never commit real values
FIEL_TEST_PATH=/var/www/html/../../Downloads/Renovacion_FIEL_AOMA940814N35_20260105151808
FIEL_TEST_PASSWORD=

# Horizon
HORIZON_NAME=Nexum
HORIZON_NOTIFICATION_EMAIL=
